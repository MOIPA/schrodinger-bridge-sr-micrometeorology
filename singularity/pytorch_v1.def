Bootstrap: docker
From: nvidia/cuda:11.7.1-cudnn8-devel-ubuntu22.04

%files
    ./docker/pytorch_v1/Pipfile /workspace/
    ./docker/pytorch_v1/Pipfile.lock /workspace/

%environment
    export PATH=/workspace/.local/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/lib/:$LD_LIBRARY_PATH
    export PIP_NO_CACHE_DIR="off"
    export WORKON_HOME=/workspace/.venvs
    export PIPENV_VENV_IN_PROJECT=1
    export PIP_DEFAULT_TIMEOUT=100

%post
    export DEBIAN_FRONTEND="noninteractive"
    export PATH=/workspace/.local/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/lib/:$LD_LIBRARY_PATH
    export PIP_NO_CACHE_DIR="off"
    export WORKON_HOME=/workspace/.venvs
    export PIPENV_VENV_IN_PROJECT=1
    export PIP_DEFAULT_TIMEOUT=100


    set -eux
    apt-get update
    apt-get install -y --no-install-recommends \
        zsh \
        less \
        git \
        wget \
        curl \
        ttf-mscorefonts-installer \
        libeccodes-dev \
        libgeos-dev \
        libgdal-dev \
        build-essential \
        python3.11 \
        python3.11-dev \
        python3-pip \
        libgl1-mesa-dev \
        libx11-dev
    apt-get autoremove -y
    apt-get clean
    rm -rf /var/lib/apt/lists/*

    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1
    update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1

    cd /workspace
    rm -rf ${HOME}/.cache/pip ${HOME}/.cache/pipenv
    pip3 freeze > uninstall.txt
    pip3 uninstall -y -r uninstall.txt
    pip3 install -U pip==24.3.1 pipenv==2024.4.0
    apt-get purge -y python3-yaml
    pipenv sync --system --dev
    rm -rf ${HOME}/.cache/pip ${HOME}/.cache/pipenv
